{
  "name": "@masuidrive/pdh-flow",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "files": [
    "lib/",
    "flows/",
    "web/bundle/",
    "README.md"
  ],
  "bin": {
    "pdh-flow": "./lib/cli.js"
  },
  "scripts": {
    "check": "tsc --project tsconfig.json",
    "smoke:calc": "node src/cli.ts smoke-calc",
    "test:runtime": "scripts/test-runtime.sh",
    "build:web": "cd web && npm ci && npm run build",
    "build:ts": "tsc --project tsconfig.build.json",
    "prepare": "npm run build:web && npm run build:ts"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/png": "^3.1.1",
    "@jsquash/resize": "^2.1.1",
    "@jsquash/webp": "^1.5.0",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "beautiful-mermaid": "^1.1.3",
    "markdown-it": "^14.1.1",
    "nunjucks": "^3.2.4",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/nunjucks": "^3.2.6",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3"
  }
}
