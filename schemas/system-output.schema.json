{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pdh-flow.dev/schemas/system-output.schema.json",
  "title": "System step output",
  "description": "Result of a system_step (deterministic runtime work: close, lease release, cleanup, barrier). No LLM involvement; engine produces this record itself.",

  "type": "object",
  "additionalProperties": false,
  "required": ["status", "node_id", "action", "started_at", "ended_at"],
  "properties": {
    "status":     { "enum": ["completed", "failed"] },
    "node_id":    { "$ref": "common.schema.json#/$defs/NodeId" },
    "action": {
      "enum": [
        "close_ticket",
        "release_lease",
        "cleanup_worktree",
        "barrier",
        "noop"
      ]
    },
    "started_at": { "$ref": "common.schema.json#/$defs/IsoDateTime" },
    "ended_at":   { "$ref": "common.schema.json#/$defs/IsoDateTime" },
    "summary":    { "type": "string", "maxLength": 280 },
    "details": {
      "type": "object",
      "description": "Action-specific data. e.g. { released_leases: [...], merge_commit: '...' }. Loose schema."
    },
    "commit_sha": {
      "$ref": "common.schema.json#/$defs/GitCommitSha",
      "description": "Optional: if the system_step produced a commit (typically only close_ticket does)."
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message"],
      "properties": {
        "kind":    { "enum": ["preflight_failed", "git_failure", "lock_timeout", "unknown"] },
        "message": { "type": "string", "minLength": 1, "maxLength": 4000 },
        "details": { "type": "string", "maxLength": 4000 }
      }
    }
  },
  "allOf": [
    {
      "if":   { "properties": { "status": { "const": "failed" } } },
      "then": { "required": ["error"] }
    }
  ]
}
