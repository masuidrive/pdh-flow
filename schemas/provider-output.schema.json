{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pdh-flow.dev/schemas/provider-output.schema.json",
  "title": "Provider step output",
  "description": "Result of a provider_step invocation. Persisted to .pdh-flow/runs/<run>/rounds/<round>/<node_id>/output.json. Engine reads on STEP_COMPLETED to populate XState context.",

  "type": "object",
  "additionalProperties": false,
  "required": ["status", "node_id", "round", "provider", "started_at", "ended_at"],
  "properties": {
    "status":     { "enum": ["completed", "failed", "cancelled", "timed_out"] },
    "node_id":    { "$ref": "common.schema.json#/$defs/NodeId" },
    "round":      { "type": "integer", "minimum": 1 },
    "provider":   { "$ref": "common.schema.json#/$defs/Provider" },
    "role":       { "type": "string", "maxLength": 64 },
    "started_at": { "$ref": "common.schema.json#/$defs/IsoDateTime" },
    "ended_at":   { "$ref": "common.schema.json#/$defs/IsoDateTime" },

    "evidence_ref": {
      "$ref": "common.schema.json#/$defs/EvidenceRef",
      "description": "Where the durable evidence (narrative + checkbox) lives. Typically kind=section pointing into current-note.md."
    },

    "commit_sha": { "$ref": "common.schema.json#/$defs/GitCommitSha" },

    "files_modified": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 },
      "description": "Repo-relative paths modified during this step (excluding gitignored)."
    },

    "summary": {
      "type": "string",
      "maxLength": 280,
      "description": "1-line summary used in commit subject and progress events."
    },

    "transcript_path": {
      "type": "string",
      "description": "Provider raw output (JSONL or similar) under .pdh-flow/runs/<>/<>. Optional; engine never consumes for transitions."
    },

    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message"],
      "properties": {
        "kind": {
          "enum": ["timeout", "subprocess_failure", "interrupted", "schema_violation", "unknown"]
        },
        "message":     { "type": "string", "minLength": 1, "maxLength": 4000 },
        "exit_code":   { "type": "integer" },
        "stderr_tail": { "type": "string", "maxLength": 4000 }
      }
    }
  },

  "allOf": [
    {
      "if":   { "properties": { "status": { "const": "completed" } } },
      "then": { "required": ["evidence_ref", "commit_sha", "summary"] }
    },
    {
      "if":   { "properties": { "status": { "enum": ["failed", "cancelled", "timed_out"] } } },
      "then": { "required": ["error"] }
    }
  ]
}
