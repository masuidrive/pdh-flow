{
  "name": "@masuidrive/pdh-flow",
  "version": "0.2.0-pre",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --project tsconfig.json",
    "cli": "node src/cli/index.ts",
    "test:validate": "scripts/test-validate.sh",
    "test:fixture-shape": "scripts/test-fixture-shape.sh",
    "test:engine": "scripts/test-engine-prototype.sh",
    "test:all": "npm run check && npm run test:validate && npm run test:fixture-shape && npm run test:engine",
    "gen:types": "json2ts --cwd schemas --input 'schemas/*.schema.json' --output src/types/generated --additionalProperties=false --enableConstEnums=false"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "xstate": "^5.31.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "json-schema-to-typescript": "^15.0.0",
    "typescript": "^6.0.3"
  }
}
