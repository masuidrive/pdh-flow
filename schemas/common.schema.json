{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pdh-flow.dev/schemas/common.schema.json",
  "title": "Common type definitions",
  "description": "Shared $defs for pdh-flow schemas. Not validated directly; only consumed via $ref.",

  "$defs": {
    "NodeId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$",
      "minLength": 1,
      "maxLength": 128,
      "description": "Lower-case dotted path. Dots indicate parent.child relationship (e.g. parallel-group member). Underscores join words within a segment."
    },

    "TicketId": {
      "type": "string",
      "pattern": "^[0-9]{6}-[0-9]{6}-[a-z0-9-]+$",
      "description": "YYMMDD-HHMMSS-slug. Matches pdh-flow's existing ticket naming."
    },

    "RunId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9_.-]+$",
      "description": "Engine-assigned run id. Opaque format; consumers must not parse."
    },

    "FlowId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "minLength": 1,
      "maxLength": 64
    },

    "VariantId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "minLength": 1,
      "maxLength": 32
    },

    "Provider": {
      "type": "string",
      "enum": ["claude", "codex"],
      "description": "Subprocess CLI provider. New providers added here as the matrix grows."
    },

    "Severity": {
      "type": "string",
      "enum": ["critical", "major", "minor"],
      "description": "Finding severity. critical/major are blocking by default."
    },

    "IsoDateTime": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 / ISO 8601 datetime, UTC preferred."
    },

    "GitCommitSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$",
      "description": "Hex commit sha; full or short form."
    },

    "EvidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": ["file", "section", "commit", "node_output"],
          "description": "file=path; section=path+section; commit=sha; node_output=node_id+round."
        },
        "path": { "type": "string", "minLength": 1 },
        "section": { "type": "string", "minLength": 1 },
        "commit": { "$ref": "#/$defs/GitCommitSha" },
        "node_id": { "$ref": "#/$defs/NodeId" },
        "round": { "type": "integer", "minimum": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "file" } } },
          "then": { "required": ["path"] }
        },
        {
          "if": { "properties": { "kind": { "const": "section" } } },
          "then": { "required": ["path", "section"] }
        },
        {
          "if": { "properties": { "kind": { "const": "commit" } } },
          "then": { "required": ["commit"] }
        },
        {
          "if": { "properties": { "kind": { "const": "node_output" } } },
          "then": { "required": ["node_id", "round"] }
        }
      ]
    }
  }
}
