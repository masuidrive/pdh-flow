{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pdh-flow.dev/schemas/flow.schema.json",
  "title": "Flow YAML",
  "description": "Author-facing flow definition. Macros (e.g. review_loop) are allowed here; loader expands them to flat-flow.json before the engine consumes them. This is the primary contract between flow authors and the engine.",

  "type": "object",
  "additionalProperties": false,
  "required": ["flow", "version", "variants", "nodes", "providers"],
  "properties": {
    "flow":     { "$ref": "common.schema.json#/$defs/FlowId" },
    "version":  { "const": 1 },
    "defaults": { "$ref": "#/$defs/Defaults" },

    "providers": {
      "type": "object",
      "minProperties": 1,
      "required": ["default"],
      "patternProperties": {
        "^[a-z][a-z0-9_-]*$": { "$ref": "#/$defs/ProviderProfile" }
      },
      "additionalProperties": false,
      "description": "Named provider profiles. At least one profile named `default` is required — that's the profile the engine falls back to when --providers is not passed. Add additional named profiles (e.g. `codex`, `sonnet-budget`) to swap the provider matrix at run time without forking the flow file."
    },

    "variants": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": { "$ref": "#/$defs/Variant" }
      },
      "additionalProperties": false,
      "description": "Variant id (full / light / etc.) → Variant config."
    },

    "nodes": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$": { "$ref": "#/$defs/Node" }
      },
      "additionalProperties": false
    }
  },

  "$defs": {

    "Variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial"],
      "properties": {
        "initial": { "$ref": "common.schema.json#/$defs/NodeId" },
        "label":   { "type": "string", "maxLength": 80 }
      }
    },

    "Defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeout_minutes":      { "type": "integer", "minimum": 1, "maximum": 1440 },
        "idle_timeout_minutes": { "type": "integer", "minimum": 1, "maximum": 1440 },
        "max_attempts":         { "type": "integer", "minimum": 1, "maximum": 10 },
        "max_rounds":           { "type": "integer", "minimum": 1, "maximum": 20 }
      }
    },

    "Node": {
      "oneOf": [
        { "$ref": "#/$defs/ProviderStepNode" },
        { "$ref": "#/$defs/GuardianStepNode" },
        { "$ref": "#/$defs/GateStepNode" },
        { "$ref": "#/$defs/SystemStepNode" },
        { "$ref": "#/$defs/TerminalNode" },
        { "$ref": "#/$defs/ReviewLoopMacro" }
      ]
    },

    "Transition": {
      "description": "Either a NodeId (uniform target) or a variant-keyed map { full: 'a', light: 'b' }.",
      "oneOf": [
        { "$ref": "common.schema.json#/$defs/NodeId" },
        {
          "type": "object",
          "minProperties": 1,
          "patternProperties": {
            "^[a-z][a-z0-9_]*$": { "$ref": "common.schema.json#/$defs/NodeId" }
          },
          "additionalProperties": false
        }
      ]
    },

    "ProviderProfile": {
      "type": "object",
      "minProperties": 1,
      "required": ["default"],
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$|^default$": { "$ref": "common.schema.json#/$defs/Provider" }
      },
      "description": "Maps a node-id or role to a concrete provider. The required `default` key is the fallback used when neither the node-id nor the role is explicitly listed. Resolution priority at invocation time: exact node-id > role > default. Example: { default: opus, investigate_plan: codex, devils_advocate: sonnet }."
    },

    "CountSpec": {
      "description": "Either a non-negative integer (uniform across variants) or a variant-keyed map { full: 2, light: 1 } resolved at flow-load time against the active variant.",
      "oneOf": [
        { "type": "integer", "minimum": 0, "maximum": 16 },
        {
          "type": "object",
          "minProperties": 1,
          "patternProperties": {
            "^[a-z][a-z0-9_]*$": { "type": "integer", "minimum": 0, "maximum": 16 }
          },
          "additionalProperties": false
        }
      ]
    },

    "ProviderStepNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type":      { "const": "provider_step" },
        "role":      { "type": "string", "minLength": 1, "maxLength": 64 },
        "prompt":    { "$ref": "#/$defs/PromptSpec" },

        "on_done":    { "$ref": "#/$defs/Transition" },
        "on_failure": { "$ref": "#/$defs/Transition" },

        "timeout_minutes": { "type": "integer", "minimum": 1 },
        "max_attempts":    { "type": "integer", "minimum": 1 },

        "label":       { "type": "string", "maxLength": 80 },
        "summary":     { "type": "string", "maxLength": 280 },
        "viewer_hint": { "type": "string", "maxLength": 200 },

        "resume_session_from": {
          "$ref": "common.schema.json#/$defs/NodeId",
          "description": "F-001 (engineer-resume): node id whose recorded provider session this step should resume. The engine looks up .pdh-flow/runs/<runId>/sessions/<resume_session_from>.json; on hit, the provider is invoked with --resume <id>. On miss or resume failure, falls back to a fresh invocation. Typically populated by the review_loop macro expander when repair.via=resume."
        },
        "enable_user_input": {
          "type": "boolean",
          "default": false,
          "description": "F-012 (in-step turn loop): when true, this provider_step uses the provider-step-output envelope (kind: final | ask). On `ask`, the engine writes a turn-question.json and polls for turn-answer.json before resuming the provider session. Default false — provider output is unconstrained free text and the step is a single-shot."
        }
      },
      "$comment": "on_done is required for top-level nodes; nodes inside a parallel group inherit the group's on_all_done. Engine validates this consistency at load time."
    },

    "GuardianStepNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "outputs"],
      "properties": {
        "type":     { "const": "guardian_step" },
        "role":     { "type": "string", "default": "aggregator", "maxLength": 64 },

        "inputs_from": {
          "description": "Reviewer / source nodes whose output the guardian must read. Single id or list.",
          "oneOf": [
            { "$ref": "common.schema.json#/$defs/NodeId" },
            {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "common.schema.json#/$defs/NodeId" }
            }
          ]
        },

        "outputs":    { "$ref": "#/$defs/GuardianOutputs" },
        "max_rounds": { "type": "integer", "minimum": 1, "default": 1 },

        "label":   { "type": "string", "maxLength": 80 },
        "summary": { "type": "string", "maxLength": 280 }
      }
    },

    "GuardianOutputs": {
      "description": "Maps each guardian decision value to a transition target. `pass` is mandatory; the rest are optional but at least one of {repair_needed, abort, escalate_human} should be wired so non-pass decisions resolve.",
      "type": "object",
      "additionalProperties": false,
      "required": ["pass"],
      "properties": {
        "pass":           { "$ref": "#/$defs/Transition" },
        "repair_needed":  { "$ref": "#/$defs/RepairTransition" },
        "abort":          { "$ref": "#/$defs/Transition" },
        "escalate_human": { "$ref": "#/$defs/Transition" }
      }
    },

    "RepairTransition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["next"],
      "properties": {
        "next":                  { "$ref": "common.schema.json#/$defs/NodeId" },
        "max_round_escalation":  { "$ref": "common.schema.json#/$defs/NodeId" }
      }
    },

    "GateStepNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "outputs"],
      "properties": {
        "type":          { "const": "gate_step" },
        "approver_role": { "type": "string", "default": "operator", "maxLength": 64 },
        "show": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "diff",
              "judgement_summary",
              "guardian_reasoning",
              "evidence",
              "blocking_findings",
              "git_log",
              "related_tickets"
            ]
          }
        },
        "outputs": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "approved":  { "$ref": "#/$defs/Transition" },
            "rejected":  { "$ref": "#/$defs/Transition" },
            "cancelled": { "$ref": "#/$defs/Transition" }
          }
        },
        "form": {
          "type": "array",
          "items": { "$ref": "#/$defs/FormField" }
        },
        "label":   { "type": "string", "maxLength": 80 },
        "summary": { "type": "string", "maxLength": 280 }
      }
    },

    "FormField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind"],
      "properties": {
        "name":     { "type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 64 },
        "kind":     { "enum": ["text", "textarea", "select", "checkbox"] },
        "required": { "type": "boolean", "default": false },
        "label":    { "type": "string", "maxLength": 80 },
        "options": {
          "type": "array",
          "items": { "type": "string", "maxLength": 80 },
          "description": "Required when kind=select."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "select" } } },
          "then": { "required": ["options"], "properties": { "options": { "minItems": 1 } } }
        }
      ]
    },

    "SystemStepNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "action", "on_done"],
      "properties": {
        "type": { "const": "system_step" },
        "action": {
          "enum": [
            "close_ticket",
            "close_epic",
            "release_lease",
            "cleanup_worktree",
            "barrier",
            "noop",
            "run_qa_script"
          ]
        },
        "params":      { "type": "object" },
        "on_done":     { "$ref": "#/$defs/Transition" },
        "on_failure":  { "$ref": "#/$defs/Transition" },
        "label":       { "type": "string", "maxLength": 80 }
      }
    },

    "TerminalNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "outcome"],
      "properties": {
        "type":    { "const": "terminal" },
        "outcome": { "enum": ["success", "aborted", "needs_human"] },
        "reason":  { "type": "string", "maxLength": 280 }
      }
    },

    "ReviewLoopMacro": {
      "type": "object",
      "additionalProperties": false,
      "required": ["macro", "reviewers", "on_pass"],
      "properties": {
        "macro": { "const": "review_loop" },
        "reviewers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ReviewerSpec" }
        },
        "aggregator": {
          "anyOf": [
            { "$ref": "#/$defs/AggregatorSpec" },
            { "type": "null" }
          ],
          "description": "When null, no aggregate node is generated and the macro degenerates to a single-reviewer pass-through."
        },
        "repair": {
          "anyOf": [
            { "$ref": "#/$defs/RepairSpec" },
            { "type": "null" }
          ],
          "description": "When null, no repair node is generated and max_rounds must be 1."
        },
        "max_rounds": { "type": "integer", "minimum": 1, "maximum": 20, "default": 1 },
        "on_pass":    { "$ref": "#/$defs/Transition" },
        "on_aborted": { "$ref": "#/$defs/Transition" },
        "label":      { "type": "string", "maxLength": 80 },
        "summary":    { "type": "string", "maxLength": 280 }
      },
      "allOf": [
        {
          "if":   { "properties": { "repair": { "type": "null" } } },
          "then": { "properties": { "max_rounds": { "const": 1 } } }
        }
      ]
    },

    "ReviewerSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role"],
      "properties": {
        "role": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "count":    { "$ref": "#/$defs/CountSpec" },
        "focus": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 200 }
        }
      },
      "$comment": "count=0 (or a variant-keyed entry resolving to 0) instructs the loader to skip this reviewer for that variant. Provider for each reviewer is resolved at invocation time from the active providers profile (role lookup)."
    },

    "AggregatorSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "role":     { "type": "string", "default": "aggregator", "maxLength": 64 }
      }
    },

    "RepairSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "role":     { "type": "string", "default": "repair", "maxLength": 64 },
        "via": {
          "enum": ["separate_node", "resume"],
          "default": "separate_node",
          "description": "F-001 (engineer-resume): when 'separate_node', a fresh provider is spawned with the repair role on each repair_needed (current default behavior). When 'resume', the engine resumes the upstream node named in `resume_node` via --resume <session_id>; the repair role's prompt is delivered as the next user message in that session."
        },
        "resume_node": {
          "$ref": "common.schema.json#/$defs/NodeId",
          "description": "Required when via=resume. Node id whose recorded provider session is resumed (typically the implement / planner node feeding this review_loop)."
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["via"],
            "properties": { "via": { "const": "resume" } }
          },
          "then": { "required": ["resume_node"] }
        }
      ]
    },

    "PromptSpec": {
      "description": "Prompt-author hints. Engine extends this with system context (current state, evidence refs) when invoking the provider. Open shape on purpose: prompts are domain-specific.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "intent":         { "type": "string", "maxLength": 1000 },
        "note_section":   { "type": "string", "maxLength": 200 },
        "commit_summary": { "type": "string", "maxLength": 80 },
        "checkpoints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        }
      }
    }
  }
}
