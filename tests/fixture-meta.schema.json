{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pdh-flow.dev/schemas/fixture-meta.schema.json",
  "title": "v2 fixture meta",
  "description": "Test fixture metadata. Lives at tests/fixtures/v2/<scenario>/meta.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["scenario", "starting_node", "expected_decisions", "expected_terminal_node"],
  "properties": {
    "scenario": { "type": "string", "minLength": 1, "maxLength": 128 },
    "description": { "type": "string", "maxLength": 1000 },
    "starting_node": { "type": "string", "minLength": 1 },
    "flow_id": { "type": "string", "default": "pdh-c-v2" },
    "variant": { "type": "string", "default": "full" },

    "expected_decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["node", "round", "decision"],
        "properties": {
          "node": { "type": "string", "minLength": 1 },
          "round": { "type": "integer", "minimum": 1 },
          "decision": { "enum": ["pass", "repair_needed", "abort", "approved", "rejected", "completed"] }
        }
      }
    },

    "expected_terminal_node": { "type": "string", "minLength": 1 },

    "expected_commits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["subject_pattern"],
        "properties": {
          "subject_pattern": { "type": "string", "minLength": 1 },
          "min_count": { "type": "integer", "minimum": 1, "default": 1 }
        }
      }
    },

    "node_outputs": {
      "type": "object",
      "description": "Per-node fixture content. Keyed by node_id; values describe what the fake provider should write per round.",
      "patternProperties": {
        "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^round-[0-9]+$": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "note_section": { "type": "string" },
                "summary": { "type": "string", "maxLength": 280 },
                "guardian_output": { "type": "object" },
                "files": {
                  "type": "object",
                  "description": "Map of repo-relative path → file content the fake provider writes.",
                  "additionalProperties": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "additionalProperties": false
    }
  }
}
