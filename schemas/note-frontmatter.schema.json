{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pdh-flow.dev/schemas/note-frontmatter.schema.json",
  "title": "current-note.md frontmatter",
  "description": "Canonical runtime state. The XState snapshot is bookkeeping; if missing or corrupt, the engine rebuilds the machine from this frontmatter + judgements/ + git history. Authority order on conflict: this frontmatter > XState snapshot.",

  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "ticket_id",
    "flow",
    "variant",
    "run_id",
    "current_node_id",
    "round",
    "status",
    "started_at",
    "last_advanced_at"
  ],
  "properties": {
    "version":          { "const": 1 },
    "ticket_id":        { "$ref": "common.schema.json#/$defs/TicketId" },
    "flow":             { "$ref": "common.schema.json#/$defs/FlowId" },
    "variant":          { "$ref": "common.schema.json#/$defs/VariantId" },
    "run_id":           { "$ref": "common.schema.json#/$defs/RunId" },
    "current_node_id":  { "$ref": "common.schema.json#/$defs/NodeId" },
    "round": {
      "type": "integer",
      "minimum": 1,
      "description": "Round counter, scoped to the active review_loop. 1 for nodes outside any loop."
    },
    "status": {
      "enum": ["in_progress", "needs_human", "completed", "aborted", "cancelled"]
    },
    "started_at":        { "$ref": "common.schema.json#/$defs/IsoDateTime" },
    "last_advanced_at":  { "$ref": "common.schema.json#/$defs/IsoDateTime" },
    "completed_at":      { "$ref": "common.schema.json#/$defs/IsoDateTime" },

    "needs_human": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "node_id", "since"],
      "properties": {
        "reason": {
          "enum": [
            "gate_pending",
            "max_rounds_exceeded",
            "explicit_pause",
            "schema_violation",
            "guardian_violation",
            "preflight_failed",
            "error"
          ]
        },
        "node_id": { "$ref": "common.schema.json#/$defs/NodeId" },
        "since":   { "$ref": "common.schema.json#/$defs/IsoDateTime" },
        "details": { "type": "string", "maxLength": 1000 }
      }
    },

    "history": {
      "type": "array",
      "description": "Brief trail of completed nodes for fast UI rendering. Authoritative history is git log + judgements/. Entries appended on every node completion.",
      "items": { "$ref": "#/$defs/HistoryEntry" }
    }
  },
  "allOf": [
    {
      "if":   { "properties": { "status": { "const": "needs_human" } } },
      "then": { "required": ["needs_human"] }
    },
    {
      "if":   { "properties": { "status": { "const": "completed" } } },
      "then": { "required": ["completed_at"] }
    }
  ],

  "$defs": {
    "HistoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "round", "outcome", "at"],
      "properties": {
        "node_id":    { "$ref": "common.schema.json#/$defs/NodeId" },
        "round":      { "type": "integer", "minimum": 1 },
        "outcome": {
          "enum": [
            "completed",
            "failed",
            "approved",
            "rejected",
            "passed",
            "repair_needed",
            "aborted",
            "escalated"
          ]
        },
        "at":         { "$ref": "common.schema.json#/$defs/IsoDateTime" },
        "commit_sha": { "$ref": "common.schema.json#/$defs/GitCommitSha" },
        "summary":    { "type": "string", "maxLength": 280 }
      }
    }
  }
}
